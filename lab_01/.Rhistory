table(laptop$HDD)
# Memory size
laptop$Memory_size <- as.numeric(gsub("[^0-9]", "", laptop$Memory))
summary(laptop$Memory_size)
# Resolution
laptop$Resolution <- regmatches(laptop$ScreenResolution,
regexpr("[0-9]+x[0-9]+", laptop$ScreenResolution))
# Tách width và height
res_split <- strsplit(laptop$Resolution, "x")
laptop$Res_width <- as.numeric(sapply(res_split, `[`, 1))
laptop$Res_height <- as.numeric(sapply(res_split, `[`, 2))
# PPI
laptop$PPI <- sqrt(laptop$Res_width^2 + laptop$Res_height^2) / laptop$Inches
summary(laptop$PPI)
str(laptop)
summary(laptop)
sum(!complete.cases(laptop)) # Phải = 0
sum(duplicated(laptop)) # Phải = 0
write.csv(laptop, "laptop_cleaned.csv", row.names = FALSE)
