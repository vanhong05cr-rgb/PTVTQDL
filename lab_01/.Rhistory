xlab = "Loài",
ylab = "Petal Length")
data(mtcars)
plot(mtcars$hp,
mtcars$mpg,
col = colors[mtcars$cyl],
pch = 19,
main = "Mối quan hệ giữa Horsepower và MPG",
xlab = "Horsepower (hp)",
ylab = "Miles per Gallon (mpg)")
model <- lm(mpg ~ hp, data = mtcars)
abline(model, col = "black", lwd = 2)
legend("topright",
legend = c("4 cyl", "6 cyl", "8 cyl"),
col = colors,
pch = 19)
par(mfrow = c(2,2))
hist(mtcars$hp,
col = "skyblue",
main = "Histogram of HP",
xlab = "Horsepower")
boxplot(mtcars$hp,
col = "orange",
main = "Boxplot of HP")
boxplot(hp ~ cyl,
data = mtcars,
col = c("red","blue","green"),
main = "HP theo số cyl")
plot(mtcars$hp,
mtcars$mpg,
col = "violet",
pch = 19,
main = "HP vs MPG",
xlab = "HP",
ylab = "MPG")
# Tạo dữ liệu bán hàng của 4 quý
Q1 <- c(100, 120, 110, 130)
Q2 <- c(150, 140, 160, 155)
Q3 <- c(180, 170, 190, 185)
Q4 <- c(200, 210, 195, 220)
products <- c("Sản phẩm A", "Sản phẩm B", "Sản phẩm C", "Sản phẩm D")
sales <- rbind(Q1,Q2,Q3,Q4)
barplot(sales,
beside = TRUE,
col = c("red","blue","green","orange"),
names.arg = products,
main = "Doanh thu 4 quý",
legend = c("Q1","Q2","Q3","Q4"))
matplot(t(sales),
type = "b",
pch = 19,
col = 1:4,
xaxt = "n",
xlab = "Quý",
ylab = "Doanh thu",
main = "Doanh thu theo quý")
axis(1, at = 1:4, labels = c("Q1","Q2","Q3","Q4"))
legend("topleft",
legend = products,
col = 1:4,
pch = 19)
total_quarter <- colSums(sales)
barplot(total_quarter,
col = "skyblue",
main = "Tổng doanh thu mỗi quý",
xlab = "Quý",
ylab = "Doanh thu")
par(mfrow = c(2,2))
barplot(sales,
beside = TRUE,
col = c("red","blue","green","orange"),
names.arg = products,
main = "Grouped Bar Chart")
matplot(t(sales),
type = "b",
pch = 19,
col = 1:4,
xaxt = "n",
main = "Line Plot")
axis(1, at = 1:4, labels = c("Q1","Q2","Q3","Q4"))
pie(total_quarter,
col = rainbow(4),
main = "Tổng doanh thu mỗi quý")
total_product <- rowSums(sales)
barplot(total_product,
col = "lightgreen",
main = "Tổng doanh thu mỗi sản phẩm",
names.arg = c("Q1","Q2","Q3","Q4"))
