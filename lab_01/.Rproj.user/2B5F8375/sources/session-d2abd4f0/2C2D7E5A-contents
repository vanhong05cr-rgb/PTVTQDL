# 1. Load và Khám phá Dữ liệu

# Load dữ liệu
price<-read.csv("D:/PTVTQDL/data/laptops.csv")
View(price)

# Xem 6 dòng đầu
head(price)

# Kiểm tra cấu trúc
str(price)

# Tóm tắt thống kê
summary(price)

# Loại bỏ cột đầu tiên
head(price[,-1]) # Xem trước khi xóa
price<-price[,-1] # Xóa cột 1: cột id


# 2. Xử lí Missing Data

# Phát hiện missing data
# Tìm các dòng có dữ liệu thiếu
price[!complete.cases(price),]

# Đếm số dòng bị thiếu
length(price[!complete.cases(price),])

# Xử lí biến số Numeric
# Xử lí cột Ram
price$Ram<-as.numeric(gsub("GB","",price$Ram))

# Xử lí cột Weight
price$Weight<-as.numeric(gsub("kg","", price$Weight))

# Kiểm tra Missing Data sau khi chuyển đổi
price[!complete.cases(price),]

# Kiểm tra tóm tắt sau khi chuyển thành số
summary(price$Ram)
summary(price$Weight)


# 3. Chuyển đổi Categorical Data thành Factor
# Company - Thương hiệu
summary(factor(price$Company))
price$Company<-factor(price$Company)

# TypeName - Loại máy
summary(factor(price$TypeName))
price$TypeName<-factor(price$TypeName)
# OpSys - Hệ điều hành
summary(factor(price$OpSys))
price$OpSys<-factor(price$OpSys)

# 4. Tự động hóa với lapply()
# Liệt kê các cột dạng phân loại
catVariables<-c("Company", "TypeName", "Cpu", "Gpu", "OpSys")

# Xem tóm tắt nhanh số lượng từng loại bằng lapply
lapply(price[,catVariables], function(x) { summary(factor(x)) })

# Chuyển đổi hàng loạt sang Factor
price[, catVariables]<-lapply(price[, catVariables], factor)


# 5. Trích xuất thông tin
# Sử dụng thư viện Stringr
price$Resolution<-sub(".*", "", price$ScreenResolution)

# Chuyển thành factor để phân loại độ sắc nét
price$Resolution<-factor(price$Resolution)
summary(price$Resolution)


# 6. Kiểm tra kết quả và lưu
# Kiểm tra lại cấu trúc
str(price)

# Xem tóm tắt thống kê giá tiền
summary(price$Price_euros)

# Kiểm tra còn dữ liệu thiếu không
sum(is.na(price))

# Lưu dữ liệu sạch
write.csv(price, "laptop_prices_cleaned.csv", row.names = FALSE)
